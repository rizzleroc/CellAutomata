# ── CellAuto Pro — environment template ───────────────────────────────────────
# Copy to `.env` for local dev, or paste these into Railway → service → Variables.
# `.env` is gitignored. NEVER commit real keys or codes (test OR live) to the
# repo — they live in Railway's Variables tab or a local `.env` only.
#
# Three ways to run before the full Clerk/Stripe flow is live:
#
#   A) SIMPLEST — a shared access code people type on the page. Set ONE var and
#      anyone who enters the matching code can render (no Clerk, no Stripe). The
#      server checks it constant-time; the render endpoint is what's protected.
#         CELLAUTO_ACCESS_CODE=pick-a-code
#
#   B) Render-only, ZERO gate — unlocks /api/render for ANYONE who hits the URL.
#      No code prompt at all. Fine locally; don't leave it on a public deploy.
#         CELLAUTO_DEV_UNLOCKED=1
#
#   C) FULL flow in test mode — Clerk Development instance + Stripe TEST mode.
#      Exercises sign-in → checkout → entitlement with fake money (test card
#      4242 4242 4242 4242, any future expiry/CVC). Fill in the *_test_* values
#      below and leave the two vars above unset. Flip to *_live_* to go live.

# ── A) Interim shared access code (simplest) ──────────────────────────────────
# Set to any string to switch web9 into "early access" mode with a code box.
# Leave empty/unset to disable. Hand the code to trial users out-of-band.
CELLAUTO_ACCESS_CODE=

# ── C) Clerk (auth) — use a Development instance for test runs ─────────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# Or set the issuer instead and the server derives the JWKS URL:
# CLERK_ISSUER=https://your-app.clerk.accounts.dev

# ── C) Stripe (billing) — use TEST mode for test runs ─────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.up.railway.app
PRO_PRICE_LABEL=$9/mo (test)

# ── Resource bounds (optional; defaults shown — keep within the hard caps) ─────
# MAX_RENDER_SIZE=4000
# MAX_RENDER_GRID=384
# MAX_RENDER_STEPS=1500

# ── B) Local-only escape hatch — NEVER set on a public deploy ──────────────────
# CELLAUTO_DEV_UNLOCKED=1
