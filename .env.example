# ── CellAuto Pro — environment template ───────────────────────────────────────
# Copy to `.env` for local dev, or paste these into Railway → service → Variables.
# `.env` is gitignored. NEVER commit real keys (test OR live) to the repo —
# they go in Railway's Variables tab or a local `.env` only.
#
# Two ways to do trial runs before the full security stack is live:
#
#   A) Render-only trial, ZERO keys — unlocks /api/render for ANYONE who hits the
#      URL. Good for trialing the render itself; it does NOT exercise sign-in or
#      checkout, and it grants Pro to every visitor — don't leave it on a public
#      deploy. Set just this and nothing else:
#         CELLAUTO_DEV_UNLOCKED=1
#
#   B) Full gate in Stripe TEST mode + a Clerk DEVELOPMENT instance (recommended
#      for "test key" trial runs) — exercises the whole flow (sign in → checkout
#      → entitlement) with fake money: Stripe test card 4242 4242 4242 4242, any
#      future expiry, any CVC. Fill in the *_test_* values below and leave
#      CELLAUTO_DEV_UNLOCKED unset. Flip to the *_live_* values to go live.

# ── Clerk (auth) — use a Development instance for test runs ────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
# Or set the issuer instead and the server derives the JWKS URL:
# CLERK_ISSUER=https://your-app.clerk.accounts.dev

# ── Stripe (billing) — use TEST mode for test runs ────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.up.railway.app
PRO_PRICE_LABEL=$9/mo (test)

# ── Resource bounds (optional; defaults shown — keep within the hard caps) ─────
# MAX_RENDER_SIZE=4000
# MAX_RENDER_GRID=384
# MAX_RENDER_STEPS=1500

# ── Local-only escape hatch — NEVER set on a public deploy ─────────────────────
# CELLAUTO_DEV_UNLOCKED=1
